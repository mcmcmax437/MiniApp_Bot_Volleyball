generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// 6-level player skill scale, per project requirements.
// LEVEL_1 = Beginner — knows the rules, basic elements inconsistent
// LEVEL_2 = Beginner (Amateur) — overhand serve, positional defense, simple receive
// LEVEL_3 = Intermediate — consistent reception, confident attacks, first group block
// LEVEL_4 = Advanced — confident play with setter, first-tempo attacks, tactical serves
// LEVEL_5 = Semi-Pro — deep tactical understanding, powerful serves/gliders, rehearsed combos
// LEVEL_6 = Professional — former pros, MS / CMS holders, excellent technique, fast teamwork
enum SkillLevel {
  LEVEL_1
  LEVEL_2
  LEVEL_3
  LEVEL_4
  LEVEL_5
  LEVEL_6
}

enum GameStatus {
  OPEN
  FULL
  CANCELLED
  FINISHED
}

enum VenueStatus {
  PUBLISHED
  HIDDEN
}

enum UserRole {
  USER
  ADMIN
}

enum ReportReason {
  TOXIC
  SKIPPED_GAME
  HARASSMENT
  CHEATING
  OTHER
}

enum ReportStatus {
  OPEN
  REVIEWED
  DISMISSED
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  DECLINED
}

enum JoinRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

// Where the game is being played. Independent from `Venue.indoor` because
// a venue tagged as "indoor sports complex" can still host an outdoor beach
// tournament, and beach games need their own filter in the Games list.
enum PlayType {
  INDOOR
  OUTDOOR
  BEACH
}

model User {
  id              String      @id @default(cuid())
  telegramId      BigInt      @unique
  firstName       String
  lastName        String?
  username        String?
  age             Int?
  skillLevel      SkillLevel?
  city            String
  lat             Float?
  lng             Float?
  // minutes before game start, e.g. [1440, 120, 30]
  reminderOffsets Json
  // Telegram profile photo URL, refreshed on every login
  photoUrl        String?
  role            UserRole    @default(USER)
  // v3 fields:
  language        String? // IETF tag e.g. "uk", "pl", "en", "ru"
  isBanned        Boolean     @default(false)
  bannedReason    String?     @db.VarChar(280)
  bannedAt        DateTime?
  // Aggregated skill from post-game evaluations (kept separate from self-declared skillLevel)
  evaluatedSkillLevel SkillLevel?
  evaluatedAt     DateTime?

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  hostedGames     Game[]            @relation("hostedBy")
  participations  GameParticipant[]
  submittedVenues Venue[]           @relation("venueSubmitter")
  auditActions    AuditLog[]        @relation("auditActor")

  blacklistOwned  Blacklist[]       @relation("BlacklistOwner")
  blacklistOf     Blacklist[]       @relation("BlacklistTarget")
  reportsFiled    Report[]          @relation("ReportFiler")
  reportsAgainst  Report[]          @relation("ReportTarget")
  reportsReviewed Report[]          @relation("ReportReviewer")
  invitationsSent GameInvitation[]  @relation("InvitationInviter")
  invitationsRecv GameInvitation[]  @relation("InvitationInvitee")
  joinRequests    GameJoinRequest[] @relation("JoinRequester")
  joinDecisions   GameJoinRequest[] @relation("JoinRequestDecider")
  payments        GamePayment[]
  evaluationsGiven GameEvaluation[] @relation("EvaluationEvaluator")
  evaluationsRecv GameEvaluation[]  @relation("EvaluationEvaluatee")
  analytics       AnalyticsEvent[]
  activity        UserActivityStats?

  @@index([city])
  @@index([role])
  @@index([isBanned])
}

model Venue {
  id            String      @id @default(cuid())
  name          String
  address       String
  lat           Float
  lng           Float
  indoor        Boolean     @default(false)
  surface       String?
  // total court cost per hour, in minor currency units (e.g. cents)
  hourlyPrice   Int
  capacity      Int
  status        VenueStatus @default(PUBLISHED)
  city          String
  submittedById String?
  submittedBy   User?       @relation("venueSubmitter", fields: [submittedById], references: [id])
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  games Game[]

  @@index([city])
  @@index([lat, lng])
  @@index([status])
}

model Game {
  id         String     @id @default(cuid())
  venueId    String
  venue      Venue      @relation(fields: [venueId], references: [id])
  hostId     String
  host       User       @relation("hostedBy", fields: [hostId], references: [id])
  startAt    DateTime
  endAt      DateTime
  skillLevel SkillLevel
  spotsTotal Int
  notes      String?
  // total court cost for this specific slot, in minor units
  totalCost  Int
  status     GameStatus @default(OPEN)
  // v3 fields:
  isClosed       Boolean  @default(false)
  currency       String   @default("UAH") // ISO 4217
  isPaid         Boolean  @default(false)
  coverImageUrl  String?  @db.VarChar(500)
  addressHint    String?  @db.VarChar(280)
  // Where the game is being played (indoor court, outdoor court, beach).
  // Defaults to OUTDOOR for back-compat with games created before this column
  // existed.
  playType       PlayType @default(OUTDOOR)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  participants   GameParticipant[]
  invitations    GameInvitation[]
  joinRequests   GameJoinRequest[]
  payments       GamePayment[]
  evaluations    GameEvaluation[]
  reports        Report[]

  @@index([startAt])
  @@index([status, startAt])
  @@index([venueId, startAt])
  @@index([hostId])
  @@index([isClosed])
  @@index([playType])
}

model GameParticipant {
  id       String   @id @default(cuid())
  gameId   String
  userId   String
  joinedAt DateTime @default(now())

  game Game @relation(fields: [gameId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])

  @@unique([gameId, userId])
  @@index([userId])
}

// Records every privileged action taken by an admin.
// targetType + targetId reference whatever entity was changed.
model AuditLog {
  id         String   @id @default(cuid())
  actorId    String
  actor      User     @relation("auditActor", fields: [actorId], references: [id])
  action     String // e.g. "user.update", "game.cancel", "venue.hide"
  targetType String // "user" | "game" | "venue"
  targetId   String
  meta       Json? // optional before/after or extra context
  createdAt  DateTime @default(now())

  @@index([actorId, createdAt])
  @@index([targetType, targetId])
}

// ===== v3 models =====

model Blacklist {
  id        String   @id @default(cuid())
  ownerId   String
  owner     User     @relation("BlacklistOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  blockedId String
  blocked   User     @relation("BlacklistTarget", fields: [blockedId], references: [id], onDelete: Cascade)
  reason    String?  @db.VarChar(280)
  createdAt DateTime @default(now())

  @@unique([ownerId, blockedId])
  @@index([ownerId])
  @@index([blockedId])
}

model Report {
  id         String       @id @default(cuid())
  reporterId String
  reporter   User         @relation("ReportFiler", fields: [reporterId], references: [id], onDelete: Cascade)
  targetId   String
  target     User         @relation("ReportTarget", fields: [targetId], references: [id], onDelete: Cascade)
  gameId     String?
  game       Game?        @relation(fields: [gameId], references: [id], onDelete: SetNull)
  reason     ReportReason
  details    String?      @db.VarChar(1000)
  status     ReportStatus @default(OPEN)
  reviewedBy String?
  reviewer   User?        @relation("ReportReviewer", fields: [reviewedBy], references: [id], onDelete: SetNull)
  reviewedAt DateTime?
  createdAt  DateTime     @default(now())

  @@index([targetId])
  @@index([reporterId])
  @@index([status])
  @@index([gameId])
}

model GameInvitation {
  id          String           @id @default(cuid())
  gameId      String
  game        Game             @relation(fields: [gameId], references: [id], onDelete: Cascade)
  inviterId   String
  inviter     User             @relation("InvitationInviter", fields: [inviterId], references: [id], onDelete: Cascade)
  inviteeId   String
  invitee     User             @relation("InvitationInvitee", fields: [inviteeId], references: [id], onDelete: Cascade)
  status      InvitationStatus @default(PENDING)
  respondedAt DateTime?
  createdAt   DateTime         @default(now())

  @@unique([gameId, inviteeId])
  @@index([inviteeId])
  @@index([inviterId])
  @@index([gameId])
}

model GameJoinRequest {
  id        String            @id @default(cuid())
  gameId    String
  game      Game              @relation(fields: [gameId], references: [id], onDelete: Cascade)
  userId    String
  user      User              @relation("JoinRequester", fields: [userId], references: [id], onDelete: Cascade)
  status    JoinRequestStatus @default(PENDING)
  decidedBy String?
  decider   User?             @relation("JoinRequestDecider", fields: [decidedBy], references: [id], onDelete: SetNull)
  decidedAt DateTime?
  createdAt DateTime          @default(now())

  @@unique([gameId, userId])
  @@index([gameId])
  @@index([userId])
  @@index([status])
}

model GamePayment {
  id        String   @id @default(cuid())
  gameId    String
  game      Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount    Int
  currency  String   @default("UAH")
  isPaid    Boolean  @default(false)
  paidAt    DateTime?
  note      String?  @db.VarChar(280)
  createdAt DateTime @default(now())

  @@unique([gameId, userId])
  @@index([gameId])
  @@index([userId])
}

model GameEvaluation {
  id          String     @id @default(cuid())
  gameId      String
  game        Game       @relation(fields: [gameId], references: [id], onDelete: Cascade)
  evaluatorId String
  evaluator   User       @relation("EvaluationEvaluator", fields: [evaluatorId], references: [id], onDelete: Cascade)
  evaluateeId String
  evaluatee   User       @relation("EvaluationEvaluatee", fields: [evaluateeId], references: [id], onDelete: Cascade)
  skillLevel  SkillLevel
  note        String?    @db.VarChar(500)
  createdAt   DateTime   @default(now())

  @@unique([gameId, evaluatorId, evaluateeId])
  @@index([gameId])
  @@index([evaluatorId])
  @@index([evaluateeId])
}

model AnalyticsEvent {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  type      String // e.g. 'click', 'screen_view', 'game_join'
  screen    String?
  target    String? // element label / selector
  meta      Json?
  createdAt DateTime @default(now())

  @@index([type])
  @@index([screen])
  @@index([target])
  @@index([createdAt])
  @@index([userId])
}

model UserActivityStats {
  userId             String   @id
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  gamesHosted        Int      @default(0)
  gamesAttended      Int      @default(0)
  gamesCancelled     Int      @default(0)
  lastActiveAt       DateTime?
  avgSessionsPerWeek Float    @default(0)
  updatedAt          DateTime @updatedAt
}