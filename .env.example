# ---------------------------------------------------------------------------
# Volleyball Mini App - environment configuration
# Copy this file to ".env" and fill in the values.
# Same .env is used for local dev AND VPS deploy (git-ignored).
#
# IMPORTANT: this template ships with structural placeholders only (empty
# values, generic `localhost`/`30d`/port-number defaults). It MUST NOT
# contain your real secrets, your Telegram user ID, your domain, or any
# other deployment-specific data — those belong ONLY in your local `.env`
# and on your server's `.env` (both git-ignored).
# ---------------------------------------------------------------------------

# --- Telegram ---------------------------------------------------------------
# Get this from @BotFather (/newbot). Keep it secret.
BOT_TOKEN=

# Telegram numeric user ID of the superadmin. When a user with this ID logs
# in, the API auto-elevates their role to ADMIN. Used to grant yourself the
# admin panel access. To find your ID, message @userinfobot on Telegram.
# Leave empty here — set your own ID in `.env`.
TELEGRAM_SUPERADMIN_ID=

# --- Production domain (also used by npm run deploy:vps) -------------------

# Public HTTPS URL where the Mini App is served (used by the bot's "Open app"
# button and as the WEBAPP_URL). Telegram Mini Apps require HTTPS.
PUBLIC_URL=

# Bare domain (host only) that the deploy script uses to configure nginx +
# Let's Encrypt. Use "localhost" for local testing without TLS.
DOMAIN=
# Telegram domain for the Mini App. Use "localhost" for local testing without TLS.
# --- Auth -------------------------------------------------------------------

# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=
JWT_EXPIRES_IN=30d

# --- Database (MySQL) — local dev -------------------------------------------

MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_ROOT_PASSWORD=
MYSQL_DATABASE=
MYSQL_HOST=localhost
LOCAL_DB_PORT=3306
# Prisma reads DATABASE_URL directly. The deploy script generates this from
# VPS_MYSQL_* on the server. For local dev, point it at your local MySQL:
DATABASE_URL=

# --- Database — VPS production (optional overrides for npm run deploy:vps) --
# Use when local dev MySQL credentials differ from the VPS app user.
# VPS_MYSQL_USER=
# VPS_MYSQL_PASSWORD=
# VPS_MYSQL_DATABASE=

# --- API --------------------------------------------------------------------

NODE_ENV=development
# Port 4017 — chosen to never collide with anything else. The taxi project on
# this VPS uses 3000. The deploy script's nginx template and PM2 ecosystem
# both honour this.
PORT=4017
# Comma-separated allowed origins. For production set to your PUBLIC_URL.
CORS_ORIGINS=

# --- Launch defaults --------------------------------------------------------
# City / coordinates used the very first time a user logs in (no location
# yet). Defaults are intentionally empty — pick your own in `.env`.
DEFAULT_CITY=
DEFAULT_CITY_LAT=
DEFAULT_CITY_LNG=

# --- Mini App (build-time) --------------------------------------------------
# Base path for API calls from the Mini App. Must include the /v1 prefix
# because the NestJS API sets app.setGlobalPrefix('api/v1') in main.ts.
# Same-origin "/api/v1" in production behind nginx.
VITE_API_BASE=/api/v1
