# Multi-stage build for the React Mini App.
FROM node:20-alpine AS builder
WORKDIR /app

COPY package.json package-lock.json* ./
COPY apps/api/package.json apps/api/package.json
COPY apps/mini-app/package.json apps/mini-app/package.json

RUN npm install --legacy-peer-deps

COPY apps/mini-app ./apps/mini-app
COPY apps/api ./apps/api

# Default to the relative /api path so nginx in this stack can proxy to the
# `api` service. Override at build time: --build-arg VITE_API_BASE=...
ARG VITE_API_BASE=/api/v1
ENV VITE_API_BASE=${VITE_API_BASE}

RUN npm run build:web

# Stage 2: serve via nginx.
FROM nginx:1.27-alpine AS runner
COPY --from=builder /app/apps/mini-app/dist /usr/share/nginx/html
COPY docker/nginx.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
